<% layout("/layouts/boilerplate") %>
<body>
  <style>
    #filters-container {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
    }

    #filters {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      overflow-x: auto;
      flex-grow: 1;
      scrollbar-width: none;
    }

    #filters::-webkit-scrollbar {
      display: none;
    }

    .filter {
      text-align: center;
      margin-right: 2rem;
      margin-top: 1.5rem;
      opacity: 0.7;
      text-decoration: none;
      color: inherit;
      transition: 0.2s;
      flex-shrink: 0;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
      border-bottom: 2px solid #fe424d;
    }

    .filter p {
      font-size: 0.75rem;
      margin-top: 0.25rem;
    }

    .tax-toggle {
      border: 1px solid rgba(0, 0, 0, 0.2);
      border-radius: 1rem;
      height: 3.25rem;
      padding: 0 1rem;
      display: flex;
      align-items: center;
      margin-left: 2rem;
      white-space: nowrap;
    }

    /* Tax info starts hidden */
    .tax-info {
      display: none;
    }

    @media (max-width: 992px) {
      .tax-toggle {
        margin-top: 1rem;
        margin-left: 0;
        width: 100%;
        justify-content: center;
      }
    }

    @media (max-width: 600px) {
      .card-img-top {
        height: 16rem !important;
      }
    }
  </style>

  <div id="filters-container">
    <div id="filters">
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </a>
      <a href="/listings?category=Rooms" class="filter">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
      </a>
      <a href="/listings?category=Iconic Cities" class="filter">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic Cities</p>
      </a>
      <a href="/listings?category=Mountains" class="filter">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
      </a>
      <a href="/listings?category=Castles" class="filter">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castles</p>
      </a>
      <a href="/listings?category=Amazing Pools" class="filter">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
      </a>
      <a href="/listings?category=Camping" class="filter">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </a>
      <a href="/listings?category=Farms" class="filter">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
      </a>
      <a href="/listings?category=Arctic" class="filter">
        <div><i class="fa-solid fa-snowflake"></i></div>
        <p>Arctic</p>
      </a>
      <a href="/listings?category=Domes" class="filter">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
      </a>
      <a href="/listings?category=Beach" class="filter">
        <div><i class="fa-solid fa-umbrella-beach"></i></div>
        <p>Beach</p>
      </a>
    </div>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
      </div>
    </div>
  </div>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if(allListings.length > 0) { %>
    <% for(let listing of allListings){ %>
      <a href="/listings/<%=listing._id%>" class="listing-link">
        <div class="card col listing-card h-100 border-0">
          <img 
            src="<%= listing.image.url %>" 
            class="card-img-top" 
            alt="listing_image" 
            style="height: 20rem; border-radius: 1rem;"
            onerror="this.src='https://images.unsplash.com/photo-1501785888041-af3ef285b470?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80'"
          >
          <div class="card-img-overlay"></div>
          <div class="card-body px-0">
            <p class="card-text">
              <b><%= listing.title %></b> <br /> 
              &#8377;<%= listing.price.toLocaleString("en-IN")%> / night
              <i class="tax-info text-secondary"> &nbsp; &nbsp; +18% GST</i>
            </p>
          </div>
        </div>
      </a>
    <% } %>
    <% } else { %>
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="row">
            <div class="col-12 text-center">
                <div class="no-results p-5 border rounded-4 bg-light shadow-sm" style="max-width: 550px;">
                    <i class="fa-solid fa-magnifying-glass mb-3" style="font-size: 4.5rem; color: #fe424d;"></i>
                    <h2 class="fw-bold">No Listings Found!</h2>
                    <p class="text-muted">
                        Sorry, we couldn't find what you were looking for. Try a different destination or category. <br>
                        Try adjusting your search or filters.
                    </p>
                    <a href="/listings" class="btn btn-danger mt-3 px-5 py-2" style="background-color: #fe424d; border: none; border-radius: 10px; font-weight: 600;">
                        Explore All Listings
                    </a>
                </div>
            </div>
        </div>
    </div>
<% } %>
   
  </div>
</body>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxinfo = document.getElementsByClassName("tax-info");
    for (let info of taxinfo) {
      if (window.getComputedStyle(info).display === "none") {
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>